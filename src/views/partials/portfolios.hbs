{{!-- Grilla de productos de una categoría --}}
<div class="row g-4">
    {{#each portfolios}}
    <div class="col-12 col-sm-6 col-lg-3" data-category="{{category}}">
        <article class="product-card">
            <!-- Imagen del producto -->
            <div class="product-thumb">
                <img src="{{image.secure_url}}" alt="{{title}}" loading="lazy" />
            </div>
            <!-- Contenido -->
            <div class="product-body">
                <span class="product-category">{{category}}</span>
                <h3 class="product-title">{{title}}</h3>
                <p class="product-desc">{{description}}</p>
                <!-- Precio y compra -->
                <div class="product-footer">
                    <span class="product-price">{{money price}}</span>
                    <form class="purchase-form">
                        <label class="visually-hidden" for="quantity-{{_id}}">Cantidad</label>
                        <input type="number" id="quantity-{{_id}}" name="quantity" min="1" value="1"
                            class="form-control product-qty" aria-label="Cantidad">
                        <button type="button" class="btn btn-primary btn-agregar" data-id="{{_id}}"
                            data-title="{{title}}" data-description="{{description}}" data-price="{{price}}"
                            data-image="{{image.secure_url}}">
                            <i class="fas fa-cart-plus me-1"></i> Agregar
                        </button>
                    </form>
                </div>
            </div>
        </article>
    </div>

    {{else}}
    <div class="col-12">
        <p class="m-5 text-center fw-bold text-uppercase text-decoration-underline text-danger">No existen Productos
            agregados</p>
    </div>
    {{/each}}
</div>
