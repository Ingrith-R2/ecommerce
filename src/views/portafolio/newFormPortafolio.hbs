<!-- Portfolio Section-->
<section class="page-section mt-5" id="login">
    <div class="container">
        <!-- Contact Section Heading-->
        <h2 class="page-section-heading text-center text-uppercase text-secondary mb-0">Nuevo Producto</h2>
        <!-- Icon Divider-->
        <div class="divider-custom">
            <div class="divider-custom-line"></div>
            <div class="divider-custom-icon"><i class="fas fa-star"></i></div>
            <div class="divider-custom-line"></div>
        </div>

        <!-- Portfolio Section Form-->
        <div class="row justify-content-center">
            <div class="col-lg-8 col-xl-7">

                <form action="/portafolio/add" method="post" enctype="multipart/form-data">

                    <!-- Title input-->
                    <div class="mb-3">
                        <label for="title" class="form-label fw-bold">Nombre del Producto</label>
                        <input class="form-control" id="title" type="text" placeholder="Ej. Serum Vitamina C" required
                            name="title" />
                    </div>

                    <!-- Category select-->
                    <div class="mb-3">
                        <label for="category" class="form-label fw-bold">Categoría</label>
                        <select class="form-select" id="category" required name="category">
                            <option value="" disabled selected>Selecciona una categoría</option>
                            {{#each categories}}
                            <option value="{{this.name}}">{{this.name}}</option>
                            {{/each}}
                        </select>
                    </div>

                    <!-- Price input-->
                    <div class="mb-3">
                        <label for="price" class="form-label fw-bold">Precio (USD)</label>
                        <input class="form-control" id="price" type="number" step="0.01" min="0" placeholder="0.00"
                            required name="price" />
                    </div>

                    <!-- Image input-->
                    {{#if isDemo}}
                    <div class="alert alert-info py-2 mb-3">
                        <i class="fas fa-circle-info me-1"></i>
                        En modo demo la imagen se genera automáticamente a partir del nombre del producto.
                    </div>
                    {{else}}
                    <div class="mb-3">
                        <label for="image" class="form-label fw-bold">Imagen del Producto</label>
                        <input class="form-control" id="image" type="file" required name="image" />
                    </div>
                    {{/if}}

                    <!-- Description input-->
                    <div class="mb-3">
                        <label for="description" class="form-label fw-bold">Descripción del producto</label>
                        <textarea class="form-control" id="description" rows="4"
                            placeholder="Describe el producto..." required name="description"></textarea>
                    </div>

                    <!-- Submit Button-->
                    <button class="btn btn-primary btn-xl d-block w-100" type="submit">Guardar Producto</button>
                </form>
                <div class="text-end mt-3">
                    <a href="/portafolios" class="text-decoration-none">
                        <button class="btn btn-secondary btn-xl d-block w-100" type="button">Cancelar</button>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
